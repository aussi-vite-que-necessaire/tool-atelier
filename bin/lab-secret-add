#!/usr/bin/env bash
# Ajout interactif d'un secret au coffre.
# 1) choix du scope (menu)  2) nom de la variable  3) valeur (saisie masquée)
# Usage : bin/lab-secret-add   (LAB_SECRETS_KEY doit être dans l'env)
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Charge LAB_SECRETS_KEY depuis .env racine si absent de l'env
if [ -z "${LAB_SECRETS_KEY:-}" ] && [ -f "$ROOT/.env" ]; then
  set -a; . "$ROOT/.env"; set +a
fi
if [ -z "${LAB_SECRETS_KEY:-}" ]; then
  echo "Erreur : LAB_SECRETS_KEY absent (ni env, ni .env racine)." >&2
  exit 1
fi

# Construit la liste des scopes : global, sysadmin, puis chaque projet/*.env.age
SCOPES=(global sysadmin)
for f in "$ROOT"/secrets/projects/*.env.age; do
  [ -f "$f" ] || continue
  SCOPES+=("$(basename "$f" .env.age)")
done

echo "Coffres disponibles :"
i=1
for s in "${SCOPES[@]}"; do
  printf "  %2d) %s\n" "$i" "$s"
  i=$((i+1))
done
echo
read -r -p "Numéro du coffre : " choice
if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "${#SCOPES[@]}" ]; then
  echo "Choix invalide." >&2; exit 1
fi
SCOPE="${SCOPES[$((choice-1))]}"

read -r -p "Nom de la variable (ex. INFOMANIAK_API_TOKEN) : " NAME
if ! [[ "$NAME" =~ ^[A-Z_][A-Z0-9_]*$ ]]; then
  echo "Nom invalide (UPPER_SNAKE_CASE attendu)." >&2; exit 1
fi

read -r -s -p "Valeur (masquée, Entrée pour confirmer) : " VALUE
echo
if [ -z "$VALUE" ]; then
  echo "Valeur vide, abandon." >&2; exit 1
fi

echo "→ Ajout de $NAME au coffre $SCOPE…"
printf '%s' "$VALUE" | "$ROOT/bin/lab-secret" set "$SCOPE" "$NAME"
echo "OK. Vérifie avec : bin/lab-secret list $SCOPE"
echo "Pense à commit + push secrets/${SCOPE}.env.age (ou secrets/projects/${SCOPE}.env.age)."
