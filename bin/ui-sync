#!/usr/bin/env bash
# ui-sync — copie les composants partagés de packages/ui dans un projet.
#
# Le build Docker étant scopé par projet (contexte = projects/<projet>/), on ne
# peut pas importer packages/ui à la volée : on suit le modèle shadcn (copie).
# packages/ui reste la SOURCE ; ce script vendor les fichiers dans le projet avec
# un en-tête @generated. Ne pas éditer les copies — modifier packages/ui + resync.
#
# Usage :
#   bin/ui-sync <projet>          synchronise projects/<projet>
#   bin/ui-sync --check <projet>  échoue (exit 1) si une copie a dérivé de la source
#   bin/ui-sync --list            liste les fichiers gérés
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC="$ROOT/packages/ui/src"
HEADER_TEXT="/* @generated — synchronisé depuis packages/ui par bin/ui-sync. Ne pas éditer ici : modifier packages/ui puis relancer la synchro. */"

# Fichiers gérés : "<chemin source relatif à packages/ui/src> => <chemin cible relatif au projet>"
mappings() {
  cat <<'EOF'
lib/utils.ts => src/lib/utils.ts
components/button.tsx => src/components/ui/button.tsx
components/badge.tsx => src/components/ui/badge.tsx
components/card.tsx => src/components/ui/card.tsx
components/input.tsx => src/components/ui/input.tsx
components/textarea.tsx => src/components/ui/textarea.tsx
components/label.tsx => src/components/ui/label.tsx
components/select.tsx => src/components/ui/select.tsx
components/dialog.tsx => src/components/ui/dialog.tsx
components/typography.tsx => src/components/ui/typography.tsx
components/confirm-dialog.tsx => src/components/ui/confirm-dialog.tsx
components/sidebar.tsx => src/components/ui/sidebar.tsx
components/sonner.tsx => src/components/ui/sonner.tsx
components/skeleton.tsx => src/components/ui/skeleton.tsx
lib/central-url.ts => src/lib/central-url.ts
components/app-shell.tsx => src/components/ui/app-shell.tsx
EOF
}

# Génère le contenu attendu (source + en-tête @generated bien placé).
# L'en-tête vient APRÈS une éventuelle directive "use client"/"use server".
rendered() {
  local src_file="$1"
  local first
  first="$(head -n1 "$src_file")"
  case "$first" in
    '"use client"'* | "'use client'"* | '"use server"'* | "'use server'"*)
      printf '%s\n%s\n' "$first" "$HEADER_TEXT"
      tail -n +2 "$src_file"
      ;;
    *)
      printf '%s\n' "$HEADER_TEXT"
      cat "$src_file"
      ;;
  esac
}

cmd_list() {
  echo "Composants gérés par @contentos/ui :"
  mappings | while IFS= read -r line; do
    [ -z "$line" ] && continue
    echo "  - ${line%% =>*}"
  done
}

# Réécrit un chemin cible selon l'arbo du projet : les projets sans dossier
# `src/` (ex. ressources, docs) reçoivent les fichiers à la racine.
dst_path() {
  local dir="$1" rel="$2"
  if [ -d "$dir/src" ]; then
    printf '%s' "$rel"
  else
    printf '%s' "${rel#src/}"
  fi
}

resolve_proj() {
  local proj="$1"
  [ -n "$proj" ] || { echo "ui-sync: nom de projet manquant" >&2; exit 2; }
  local dir="$ROOT/projects/$proj"
  [ -d "$dir" ] || { echo "ui-sync: projet introuvable: projects/$proj" >&2; exit 2; }
  echo "$dir"
}

cmd_sync() {
  local proj="$1"
  local dir; dir="$(resolve_proj "$proj")"
  echo "→ synchronisation de @contentos/ui dans projects/$proj"
  mappings | while IFS= read -r line; do
    [ -z "$line" ] && continue
    local rel_src="${line%% =>*}"
    local rel_dst="${line##*=> }"
    local dst="$dir/$(dst_path "$dir" "$rel_dst")"
    mkdir -p "$(dirname "$dst")"
    rendered "$SRC/$rel_src" > "$dst"
    echo "  ✓ $rel_dst"
  done
  echo "Terminé. (Tokens CSS : étape manuelle, cf. packages/ui/README.md)"
}

cmd_check() {
  local proj="$1"
  local dir; dir="$(resolve_proj "$proj")"
  local drift=0
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local rel_src="${line%% =>*}"
    local rel_dst="${line##*=> }"
    local dst="$dir/$(dst_path "$dir" "$rel_dst")"
    local shown; shown="$(dst_path "$dir" "$rel_dst")"
    if [ ! -f "$dst" ]; then
      echo "  ✗ manquant: $shown"; drift=1; continue
    fi
    if ! diff -q <(rendered "$SRC/$rel_src") "$dst" >/dev/null; then
      echo "  ✗ dérive: $shown"; drift=1
    fi
  done < <(mappings)
  if [ "$drift" -ne 0 ]; then
    echo "Dérive détectée dans projects/$proj — relance bin/ui-sync $proj" >&2
    exit 1
  fi
  echo "✓ projects/$proj est à jour avec @contentos/ui"
}

main() {
  case "${1:-}" in
    --list) cmd_list ;;
    --check) shift; cmd_check "${1:-}" ;;
    "" | -h | --help)
      grep '^#' "$0" | sed 's/^# \{0,1\}//'
      ;;
    *) cmd_sync "$1" ;;
  esac
}

main "$@"
