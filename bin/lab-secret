#!/usr/bin/env bash
# Lanceur de lab-secret : installe les deps si besoin, puis exécute la CLI.
# Usage : bin/lab-secret <set|get|list|rm> [args…]  (LAB_SECRETS_KEY dans l'env)
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOL="$ROOT/tools/lab-secret"
if [ ! -d "$TOOL/node_modules" ]; then
  ( cd "$TOOL" && { npm ci 2>/dev/null || npm install; } >/dev/null )
fi
exec node "$TOOL/lab-secret.mjs" "$@"
