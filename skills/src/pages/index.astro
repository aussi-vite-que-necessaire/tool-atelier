---
import { auth } from "@/lib/auth";
import { listSkills } from "@/lib/skills-fs";
import "@/styles/global.css";

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
const skills = await listSkills();
const connected = !!session;
---
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>skills</title>
    <meta
      name="description"
      content="Hub central des skills agentiques de la suite de tools de l'atelier (contentos, ressources, media)."
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <main class="mx-auto max-w-2xl p-6">
      <header class="mb-10 flex items-baseline justify-between">
        <div>
          <h1 class="text-xl font-semibold">skills</h1>
          <p class="mt-1 text-sm text-gray-600">
            Hub des skills agentiques de la suite — contentos, ressources, media.
          </p>
        </div>
        {
          connected ? (
            <span class="text-xs text-gray-500" title={session?.user?.email ?? ""}>
              connecté
            </span>
          ) : (
            <a href="/sign-in" class="text-sm underline">Se connecter</a>
          )
        }
      </header>

      {
        skills.length === 0 ? (
          <p class="text-sm text-gray-500">Aucun skill publié.</p>
        ) : (
          <ul class="space-y-4">
            {skills.map((s) => (
              <li class="border-b border-gray-200 pb-4 last:border-0">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-baseline gap-2">
                      <h2 class="font-mono text-sm font-semibold">{s.name}</h2>
                      <span class="font-mono text-xs text-gray-500">v{s.version}</span>
                      <span class="text-xs text-gray-400">· {s.tool}</span>
                    </div>
                    <p class="mt-1 text-sm">{s.tagline}</p>
                    <p class="mt-1 text-xs text-gray-600">{s.description}</p>
                    {s.requires_mcp && s.requires_mcp.length > 0 && (
                      <p class="mt-1 text-xs text-gray-500">
                        MCP : <span class="font-mono">{s.requires_mcp.join(", ")}</span>
                      </p>
                    )}
                  </div>
                  <div class="shrink-0">
                    {
                      connected ? (
                        <a
                          href={`/api/skills/${s.name}/download`}
                          class="rounded border border-gray-300 px-3 py-1 text-xs hover:bg-gray-50"
                        >
                          télécharger
                        </a>
                      ) : (
                        <a
                          href="/sign-in"
                          class="rounded border border-gray-200 px-3 py-1 text-xs text-gray-500 hover:bg-gray-50"
                        >
                          se connecter
                        </a>
                      )
                    }
                  </div>
                </div>
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </body>
</html>
