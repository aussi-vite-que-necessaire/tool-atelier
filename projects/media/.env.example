# Auto-injectés par la plateforme au déploiement (ne pas remplir à la main) :
# DATABASE_URL=postgres://...
# RESEND_API_KEY=...        (email: true)
# EMAIL_FROM=...            (email: true — sys@avqn.ch)
# BROWSER_URL=ws://...      (browser: true — Chromium partagé browserless)
# APP_ENV=prod|<branche>    (détermine la baseURL auth + le préfixe de clés R2 preview)

# À fournir via /lab-secret (scope media) :
BETTER_AUTH_SECRET=
GEMINI_API_KEY=
MEDIA_ENGINE_SERVICE_KEY=
# Stockage R2 (API S3) :
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=image-studio
R2_PUBLIC_BASE_URL=

# Optionnel : force la baseURL auth (sinon dérivée d'APP_ENV →
# prod = https://media.lab.avqn.ch, sinon https://media-<branche>.lab.avqn.ch).
# BETTER_AUTH_URL=
