# Base dédiée aux tests (vitest + Playwright). Localhost, aucun secret.
# Évite que les tests vident la base de dev (cast).
DATABASE_URL=postgres://app:app@localhost:5432/cast_test
REDIS_URL=redis://localhost:6379
APP_URL=http://localhost:3000
# Secret de test (valeur factice, jamais un vrai secret). Requis par env.ts.
BETTER_AUTH_SECRET=test-secret
CONTENT_OS_MEDIA_STUB=1
