{
  "name": "lab-ressources",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "node --env-file=.env.local --import tsx db/seed.ts",
    "db:test:prepare": "node scripts/db-test-prepare.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "mcp-handler": "^1.0.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.24.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
