---
import { getSession, signInUrl } from "@/lib/auth";

export const prerender = false;

// Connexion déléguée au SSO de la suite (auth.contentos.ch). Si déjà connecté
// → home ; sinon on renvoie vers le provider. Cette route ne sert qu'à honorer
// les anciens liens vers /sign-in : la home redirige déjà directement vers le SSO.
const session = await getSession(Astro.request.headers);
return Astro.redirect(session ? "/" : signInUrl());
---
