# Injectés automatiquement par la plateforme au déploiement (ne pas remplir) :
# APP_URL=https://<projet>.contentos.ch
# APP_ENV=prod                 # 'prod' en prod, slug de branche en preview

# SSO de la suite — provider d'auth. Défaut prod = https://auth.contentos.ch.
# Surchargeable pour pointer une preview du provider ; inutilisé hors-prod (accès ouvert).
AUTH_URL=
