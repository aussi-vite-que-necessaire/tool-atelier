# Injecté automatiquement par la plateforme au déploiement (ne pas remplir) :
# APP_URL=https://mcp.contentos.ch
#
# Clé interne partagée présentée aux backends (scope global, injectée par
# deploy.sh). Vide/absente en preview : les backends court-circuitent la vérif.
# MCP_INTERNAL_KEY=...
#
# Les URLs des backends (media/cast/ressources) sont DÉRIVÉES de APP_URL
# (swap du sous-domaine) — rien à configurer.
# Défaut prod : AUTH_URL=https://auth.contentos.ch
