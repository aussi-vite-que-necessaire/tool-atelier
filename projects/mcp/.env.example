# Injecté automatiquement par la plateforme au déploiement (ne pas remplir) :
# APP_URL=https://mcp.contentos.ch
#
# Injecté par deploy.sh (requis au runtime, lecture paresseuse — le build n'en
# a pas besoin) : URL interne du backend media sur le réseau lab + sa service-key
# (= MEDIA_ENGINE_SERVICE_KEY côté media).
# MEDIA_INTERNAL_URL=http://media-prod-app-1:8080
# MEDIA_SERVICE_KEY=...
#
# Défaut prod : AUTH_URL=https://auth.contentos.ch
