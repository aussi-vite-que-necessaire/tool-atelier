{
  "name": "content-os-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker": "tsx watch --env-file-if-exists=.env src/worker/index.ts",
    "worker:start": "tsx src/worker/index.ts",
    "dev:all": "concurrently -n web,worker -c blue,magenta 'npm run dev' 'npm run worker'",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:test:prepare": "tsx scripts/db-test-prepare.ts",
    "db:seed": "tsx --env-file-if-exists=.env scripts/seed-dev.ts",
    "seed:redaction": "tsx --env-file-if-exists=.env scripts/seed-redaction.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:worker": "vitest run --project=worker",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@base-ui/react": "^1.5.0",
    "@google/genai": "^2.6.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/prismjs": "^1.26.6",
    "better-auth": "^1.6.11",
    "bullmq": "^5.77.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.9",
    "image-size": "^2.0.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "mcp-handler": "^1.1.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0",
    "prismjs": "^1.30.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-simple-code-editor": "^0.14.1",
    "resend": "^6.12.3",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
