# E2E test mode, must be 'true' to expose /api/__test__/* endpoints.
# Set automatically by Playwright; do not set in dev/prod.
E2E_TESTING=

# App
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://app:app@localhost:5432/cast
# Tests : base dédiée cast_test (voir .env.test, committé). Une fois :
#   npm run db:test:prepare   # crée + migre cast_test
#   npm test                  # n'efface PAS cast
# Seed d'un compte de dev (après s'être connecté une fois) :
#   npm run db:seed -- <ton-email>

# Redis
REDIS_URL=redis://localhost:6379

# Préfixe des files BullMQ (Redis central multi-tenant sur lab). Doit être
# identique côté web (enqueue) et worker. Défaut : "cast".
QUEUE_PREFIX=cast

# Email (Resend) — laisser vide en dev local pour utiliser InMemory
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Better-Auth secret (générer via `openssl rand -base64 32`)
BETTER_AUTH_SECRET=

# Worker stub : si "1", le worker generate-post n'appelle pas Claude
# et retourne un faux contenu. Utilisé en CI et tests E2E.
CONTENT_OS_AI_STUB=0

# Media engine (render PNG + génération image). Laisser vide en dev local
# pour utiliser le stub intégré (CONTENT_OS_MEDIA_STUB=1).
MEDIA_ENGINE_URL=
MEDIA_ENGINE_SERVICE_KEY=

# Media engine stub : si "1", toutes les opérations médias (renderHtmlToPng +
# generateImage) renvoient des résultats factices sans appel réseau.
# Activé automatiquement en tests via .env.test.
CONTENT_OS_MEDIA_STUB=0

# LinkedIn (publication). Crée une app LinkedIn avec le produit "Share on
# LinkedIn" (scope w_member_social) et enregistre le redirect
# ${APP_URL}/api/linkedin/callback dans les Authorized redirect URLs.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Clé de chiffrement des tokens (n'importe quelle chaîne ; dérivée en clé
# AES-256 via SHA-256).
TOKEN_ENCRYPTION_KEY=

# Stub LinkedIn : si "1", connecte un compte factice sans appeler LinkedIn
# (CI/E2E).
CONTENT_OS_LINKEDIN_STUB=0

# Version de l'API LinkedIn (YYYYMM). Une version reste active ~12 mois.
# Bumper si la publication échoue avec "NONEXISTENT_VERSION".
LINKEDIN_API_VERSION=202604

# MCP — connecteur distant (OAuth). Le serveur est sur ${APP_URL}/api/mcp.
# Ajout dans un agent (ex. Claude Code) :
#   claude mcp add --transport http content-os ${APP_URL}/api/mcp
# Le flux OAuth (login magic-link) s'ouvre à la première connexion.
